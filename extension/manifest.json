{
  "manifest_version": 3,
  "name": "CS2 Float Sniper — Arbitrage v2",
  "version": "2.0",
  "description": "Sniper de floats con filtro de spread y perfiles de arbitrage CSFloat↔Steam.",

  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://steamcommunity.com/market/listings/*"],

  "content_scripts": [
    {
      "matches": ["https://steamcommunity.com/market/listings/730/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "CS2 Float Sniper v2"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
