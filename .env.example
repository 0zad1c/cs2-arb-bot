# ─────────────────────────────────────────────────────────────
# CS2 ARB BOT — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA commites el .env real al repositorio
# ─────────────────────────────────────────────────────────────

# ── CSFloat ───────────────────────────────────────────────────
# Obtén tu API key en: https://csfloat.com/developer
CSFLOAT_API_KEY=tu_api_key_aqui

# ── Steam ──────────────────────────────────────────────────────
# Tu Steam API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=tu_steam_api_key

# Session cookies de Steam (obtener del navegador → DevTools → Application → Cookies)
# Necesarios para operaciones autenticadas
STEAM_SESSION_ID=tu_session_id
STEAM_LOGIN_SECURE=tu_login_secure_cookie
STEAM_PARENTAL=                    # Dejar vacío si no tienes PIN parental

# ── Telegram Alerts ────────────────────────────────────────────
# Crea un bot con @BotFather, obtén el token
TELEGRAM_BOT_TOKEN=tu_token_de_telegram
# Tu chat ID personal (manda un mensaje al bot y usa /getUpdates)
TELEGRAM_CHAT_ID=tu_chat_id

# ── Capital y estrategia ───────────────────────────────────────
# Capital inicial en USD disponible en Steam Wallet
CAPITAL_INICIAL=21.00

# ── Modo ───────────────────────────────────────────────────────
# 'paper'  → Simula operaciones sin ejecutarlas (ideal para testear)
# 'live'   → Ejecuta compras/ventas reales
BOT_MODE=paper

# ── Logs ────────────────────────────────────────────────────────
# Ruta a la base de datos SQLite de operaciones
DB_PATH=./data/operaciones.db

# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
